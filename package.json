{
  "name": "cadence",
  "version": "0.2.1",
  "private": true,
  "description": "A voice-first desktop companion scaffold optimized for fast turn-taking.",
  "author": "Bruce Mager <bmager@bigdumbswede.com>",
  "main": "dist-electron/main.js",
  "scripts": {
    "check": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "clean": "rimraf dist dist-electron dist-sidecar release",
    "dev": "concurrently -k -n renderer,electron,sidecar,app -c blue,green,magenta,yellow \"npm:dev:renderer\" \"npm:dev:electron\" \"npm:dev:memory-sidecar\" \"npm:dev:app\"",
    "dev:renderer": "vite",
    "dev:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --format=cjs --outdir=dist-electron --external:electron --watch",
    "dev:app": "wait-on tcp:5173 file:dist-electron/main.js tcp:8787 && cross-env CADENCE_RENDERER_URL=http://127.0.0.1:5173 electron dist-electron/main.js",
    "dev:memory-sidecar:build": "esbuild memory-sidecar/main.ts --bundle --platform=node --format=cjs --outfile=dist-sidecar/main.js --watch",
    "dev:memory-sidecar": "concurrently -k -n build,service -c blue,green \"npm:dev:memory-sidecar:build\" \"wait-on file:dist-sidecar/main.js && node --watch dist-sidecar/main.js\"",
    "build": "npm run check && npm run build:renderer && npm run build:electron && npm run build:memory-sidecar",
    "build:renderer": "vite build",
    "build:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --format=cjs --outdir=dist-electron --external:electron",
    "build:memory-sidecar": "esbuild memory-sidecar/main.ts --bundle --platform=node --format=cjs --outfile=dist-sidecar/main.js",
    "build:icon": "python scripts/generate_icon.py",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start:memory-sidecar": "node dist-sidecar/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist:win": "npm run build && electron-builder --win portable",
    "dist:dir": "npm run build && electron-builder --dir",
    "preview": "vite preview"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "esbuild": "^0.25.11",
    "globals": "^16.4.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.1.10",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "build": {
    "appId": "com.brucevibe.cadence",
    "productName": "Cadence",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "dist-sidecar/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "Cadence-${version}-portable.${ext}"
    }
  }
}
